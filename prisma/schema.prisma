generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  certificates    Certificate[]
  loginChallenges LoginChallenge[]
  sentEnvelopes   Envelope[]       @relation("EnvelopeSender")
  receivedEnvelopes Envelope[]     @relation("EnvelopeReceiver")
}

model Certificate {
  id             String   @id @default(cuid())
  userId         String
  serialNumber   String   @unique
  publicKeyPem   String
  certificatePem String
  status         String   @default("ACTIVE")
  issuedAt       DateTime @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model LoginChallenge {
  id         String   @id @default(cuid())
  userId     String
  challenge  String   @unique
  purpose    String   @default("SIGN_LOGIN")
  used       Boolean  @default(false)
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, used])
}

model Envelope {
  id           String   @id @default(cuid())
  senderId     String
  receiverId   String
  subject      String?
  ciphertext   String
  encryptedKey String
  signature    String?
  status       String   @default("UNREAD")
  createdAt    DateTime @default(now())
  readAt       DateTime?

  sender       User     @relation("EnvelopeSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User     @relation("EnvelopeReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId, status])
}